  "repository": {
    "type": "git",
    "url": "git+https://github.com/zero-code-hero/lightagent.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "coding-agent",
    "pi",
    "ollama",
    "ai",
    "agent"
  ],
  "author": "zero-code-hero",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zero-code-hero/lightagent/issues"
  },
  "homepage": "https://github.com/zero-code-hero/lightagent#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
